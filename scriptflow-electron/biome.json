{
    "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "asNeeded"
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "linter": {
        "enabled": false
    },
    "files": {
        "includes": [
            "**",
            "!**/dist/**",
            "!**/dist-electron/**",
            "!**/build/**",
            "!**/bin/**",
            "!**/obj/**",
            "!**/node_modules/**",
            "!**/*.config.js",
            "!**/*.config.cjs",
            "!**/*.config.ts"
        ]
    }
}
