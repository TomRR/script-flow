{
    "name": "script-flow",
    "productName": "ScriptFlow",
    "description": "A workflow automation tool for running scripts.",
    "author": "Tom - Robert Resing",
    "repository": {
        "type": "git",
        "url": "https://github.com/TomRR/script-flow.git"
    },
    "private": true,
    "version": "0.1.3",
    "packageManager": "bun@1.3.10",
    "main": "dist-electron/main.js",
    "scripts": {
        "dev": "vite",
        "generate:mac-icon": "bun run scripts/generate-mac-icon.ts",
        "generate:windows-icon": "bun run scripts/generate-windows-icon.ts",
        "build": "bun run dist:desktop:artifact",
        "build:desktop": "bun run tsc -b && vite build",
        "fmt": "biome format --write .",
        "fmt:check": "biome check --assist-enabled=false .",
        "lint": "eslint .",
        "preview": "vite preview",
        "release:smoke": "bun run scripts/release-smoke.ts",
        "dist:desktop:artifact": "bun run scripts/build-desktop-artifact.ts",
        "dist:update-manifests:merge": "bun run scripts/merge-update-manifests.ts",
        "test": "node node_modules/jest/bin/jest.js",
        "typecheck": "tsc -b"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tooltip": "^1.2.8",
        "autoprefixer": "^10.4.23",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "electron-updater": "^6.6.2",
        "execa": "^9.6.1",
        "lucide-react": "^0.562.0",
        "next-themes": "^0.4.6",
        "postcss": "^8.5.6",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.4.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.0.0",
        "@eslint/js": "^9.39.1",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.5",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.1",
        "concurrently": "^9.2.1",
        "electron": "^39.2.7",
        "electron-builder": "^26.0.12",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "@happy-dom/jest-environment": "^20.5.0",
        "happy-dom": "^20.5.0",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "rimraf": "^6.1.2",
        "sharp": "^0.34.5",
        "tailwindcss": "3.4.17",
        "tailwindcss-animate": "^1.0.7",
        "ts-jest": "^29.4.6",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.46.4",
        "vite": "^7.2.4",
        "vite-plugin-electron": "^0.29.0",
        "vite-plugin-electron-renderer": "^0.14.6",
        "yaml": "^2.8.2"
    }
}
