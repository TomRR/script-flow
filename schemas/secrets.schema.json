{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Scriptflow Vault Secrets",
    "type": "object",
    "description": "Secrets storage for a Scriptflow vault",
    "required": [
        "version",
        "secrets"
    ],
    "properties": {
        "$schema": {
            "type": "string",
            "format": "uri",
            "description": "Reference to this JSON schema"
        },
        "version": {
            "type": "string",
            "description": "Schema version for this secrets file"
        },
        "secrets": {
            "type": "object",
            "description": "Map of secret names to their values and encryption status",
            "additionalProperties": {
                "$ref": "#/$defs/SecretEntry"
            }
        }
    },
    "additionalProperties": false,
    "$defs": {
        "SecretEntry": {
            "type": "object",
            "required": [
                "value",
                "encrypted"
            ],
            "properties": {
                "value": {
                    "type": "string",
                    "description": "The secret value (may be encrypted or plaintext)"
                },
                "encrypted": {
                    "type": "boolean",
                    "description": "Whether the value is encrypted"
                }
            },
            "additionalProperties": false
        }
    }
}
